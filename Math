import numpy as np
import time
from dataclasses import dataclass
from typing import List, Optional
from abc import ABC, abstractmethod

# -----------------------------------------------------------------------------
# CORE DATA STRUCTURES
# -----------------------------------------------------------------------------

@dataclass
class SystemState:
    features: np.ndarray
    timestep: int
    energy: float

@dataclass
class Action:
    vector: np.ndarray
    metadata: dict

# -----------------------------------------------------------------------------
# THE FIVE DOMAINS (SHEPHERD PROTOCOL)
# -----------------------------------------------------------------------------

class RegulationDomain(ABC):
    """Rules and constraints that define boundaries and binary decisions."""
    @abstractmethod
    def validate(self, state: SystemState, action: Action) -> bool:
        pass

class PredictionDomain(ABC):
    """Mechanisms that anticipate future states from past information."""
    @abstractmethod
    def forecast(self, history: List[SystemState]) -> SystemState:
        pass

class PatternRecognitionDomain(ABC):
    """Systems that detect complex structures in data."""
    @abstractmethod
    def extract_context(self, history: List[SystemState]) -> np.ndarray:
        pass

class GenerationDomain(ABC):
    """The capacity to produce new configurations or solutions."""
    @abstractmethod
    def generate_candidates(self, context: np.ndarray, predicted: SystemState) -> List[Action]:
        pass

class CoordinatedActionDomain(ABC):
    """Agents or mechanisms that implement change in the real system."""
    @abstractmethod
    def select_and_execute(self, candidates: List[Action], current_state: SystemState) -> Action:
        pass

# -----------------------------------------------------------------------------
# CONCRETE IMPLEMENTATIONS (INDUSTRIAL HARDENING)
# -----------------------------------------------------------------------------

class ResourceRegulator(RegulationDomain):
    def __init__(self, max_action_magnitude: float):
        self.max_mag = max_action_magnitude

    def validate(self, state: SystemState, action: Action) -> bool:
        magnitude = np.linalg.norm(action.vector)
        if magnitude > self.max_mag:
            return False
        if state.energy < magnitude * 0.1:
            return False
        return True

class TimeSeriesPredictor(PredictionDomain):
    def forecast(self, history: List[SystemState]) -> SystemState:
        if len(history) < 2: return history[-1]
        recent = history[-5:]
        deltas = [recent[i].features - recent[i-1].features for i in range(1, len(recent))]
        avg_drift = np.mean(deltas, axis=0) if deltas else np.zeros_like(history[-1].features)
        return SystemState(history[-1].features + avg_drift, history[-1].timestep + 1, history[-1].energy)

class DriftPatternRecognizer(PatternRecognitionDomain):
    def extract_context(self, history: List[SystemState]) -> np.ndarray:
        if len(history) < 3: return np.zeros_like(history[0].features)
        matrix = np.array([s.features for s in history[-10:]])
        return np.var(matrix, axis=0)

class MutationGenerator(GenerationDomain):
    def __init__(self, candidate_count: int = 20):
        self.candidate_count = candidate_count

    def generate_candidates(self, context: np.ndarray, predicted: SystemState) -> List[Action]:
        candidates = []
        target = np.zeros_like(predicted.features)
        ideal_correction = target - predicted.features
        for _ in range(self.candidate_count):
            noise = np.random.normal(0, context + 0.1, size=predicted.features.shape)
            candidates.append(Action(ideal_correction + noise, {"volatility_adapted": True}))
        return candidates

class Actuator(CoordinatedActionDomain):
    def select_and_execute(self, candidates: List[Action], current_state: SystemState) -> Action:
        if not candidates: return Action(np.zeros_like(current_state.features), {"status": "null"})
        candidates.sort(key=lambda a: np.linalg.norm(current_state.features + a.vector) + (0.1 * np.linalg.norm(a.vector)))
        best_action = candidates[0]
        best_action.metadata["executed"] = True
        return best_action

# -----------------------------------------------------------------------------
# THE ORCHESTRATOR
# -----------------------------------------------------------------------------

class ConvergenceSystem:
    def __init__(self, reg, pred, pat, gen, act):
        self.regulator = reg
        self.predictor = pred
        self.pattern_recognizer = pat
        self.generator = gen
        self.actuator = act
        self.history: List[SystemState] = []

    def process_cycle(self, current_state: SystemState) -> Action:
        self.history.append(current_state)
        context = self.pattern_recognizer.extract_context(self.history)
        predicted = self.predictor.forecast(self.history)
        raw_candidates = self.generator.generate_candidates(context, predicted)
        valid_candidates = [c for c in raw_candidates if self.regulator.validate(current_state, c)]
        return self.actuator.select_and_execute(valid_candidates, current_state)

